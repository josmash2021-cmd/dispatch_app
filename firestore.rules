rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════
    // HELPERS
    // ═══════════════════════════════════════════════════════════════════

    function isOwner() {
      return request.auth != null
        && request.auth.token.email == 'royalpurplecorp@gmail.com';
    }

    function isAdmin() {
      return request.auth != null
        && (exists(/databases/$(database)/documents/admins/$(request.auth.uid))
            || request.auth.token.email == 'royalpurplecorp@gmail.com');
    }

    function isOwnerOrAdmin() {
      return isOwner() || isAdmin();
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwnDoc(docId) {
      return request.auth != null && request.auth.uid == docId;
    }

    function isNonEmptyString(field) {
      return field is string && field.size() > 0;
    }

    // ═══════════════════════════════════════════════════════════════════
    // CONFIG — admin-controlled (pricing, service zones, app mode)
    // ═══════════════════════════════════════════════════════════════════
    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isOwnerOrAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // VERIFICATIONS — identity verification documents
    // ═══════════════════════════════════════════════════════════════════
    match /verifications/{docId} {
      allow read: if isOwnerOrAdmin()
        || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated();
      allow update: if isOwnerOrAdmin()
        || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isOwnerOrAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // ADMINS — owner can create/update/delete; admins can read
    // ═══════════════════════════════════════════════════════════════════
    match /admins/{adminId} {
      allow read: if isOwnerOrAdmin();
      allow create: if isOwner();
      allow update: if isOwner();
      allow delete: if isOwner();
    }

    // ═══════════════════════════════════════════════════════════════════
    // TRIPS
    // ═══════════════════════════════════════════════════════════════════
    match /trips/{tripId} {
      allow read: if isOwnerOrAdmin()
        || (isAuthenticated() && resource.data.passengerId == request.auth.uid)
        || (isAuthenticated() && resource.data.driverId == request.auth.uid)
        || isAuthenticated(); // dispatch & driver need to read all active trips
      allow create: if isOwnerOrAdmin()
        || (isAuthenticated()
            && isNonEmptyString(request.resource.data.passengerName)
            && isNonEmptyString(request.resource.data.pickupAddress)
            && isNonEmptyString(request.resource.data.dropoffAddress))
        || isAuthenticated();
      allow update: if isOwnerOrAdmin()
        || (isAuthenticated() && resource.data.driverId == request.auth.uid)
        || (isAuthenticated() && resource.data.passengerId == request.auth.uid)
        || isAuthenticated(); // drivers need to update trip status
      allow delete: if isOwnerOrAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // USERS — includes sql_{id} documents for Cruise app photo sync
    // Any authenticated user can read/write (data is non-sensitive: photos, profile)
    // ═══════════════════════════════════════════════════════════════════
    match /users/{userId} {
      allow read: if isOwnerOrAdmin() || isAuthenticated();
      allow create: if isOwnerOrAdmin() || isAuthenticated();
      allow update: if isOwnerOrAdmin() || isAuthenticated();
      allow delete: if isOwnerOrAdmin();

      match /payment_methods/{methodId} {
        allow read: if isOwner() || isOwnDoc(userId) || isOwnerOrAdmin();
        allow create, update: if isOwnDoc(userId) || isOwnerOrAdmin();
        allow delete: if isOwner() || isOwnDoc(userId) || isOwnerOrAdmin();
      }
    }

    // ═══════════════════════════════════════════════════════════════════
    // CLIENTS — dispatch-managed rider profiles
    // ═══════════════════════════════════════════════════════════════════
    match /clients/{clientId} {
      allow read: if isOwnerOrAdmin() || isOwnDoc(clientId) || isAuthenticated();
      allow create: if isOwnerOrAdmin() || isAuthenticated();
      allow update: if isOwnerOrAdmin() || isOwnDoc(clientId) || isAuthenticated();
      allow delete: if isOwnerOrAdmin();

      match /payment_methods/{methodId} {
        allow read: if isOwner() || isOwnDoc(clientId) || isOwnerOrAdmin();
        allow create, update: if isOwnDoc(clientId) || isOwnerOrAdmin();
        allow delete: if isOwner() || isOwnDoc(clientId) || isOwnerOrAdmin();
      }
    }

    // ═══════════════════════════════════════════════════════════════════
    // DRIVERS — driver profiles, location, status
    // ═══════════════════════════════════════════════════════════════════
    match /drivers/{driverId} {
      allow read: if isOwnerOrAdmin() || isOwnDoc(driverId) || isAuthenticated();
      allow create: if isOwnerOrAdmin() || isAuthenticated();
      allow update: if isOwnerOrAdmin() || isOwnDoc(driverId) || isAuthenticated();
      allow delete: if isOwnerOrAdmin();

      match /payment_methods/{methodId} {
        allow read: if isOwner() || isOwnDoc(driverId) || isOwnerOrAdmin();
        allow create, update: if isOwnDoc(driverId) || isOwnerOrAdmin();
        allow delete: if isOwner() || isOwnDoc(driverId) || isOwnerOrAdmin();
      }
    }

    // ═══════════════════════════════════════════════════════════════════
    // AUDIT LOG — append-only, admins read
    // ═══════════════════════════════════════════════════════════════════
    match /audit_log/{logId} {
      allow read: if isOwnerOrAdmin() || isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════
    // SCHEDULED RIDES
    // ═══════════════════════════════════════════════════════════════════
    match /scheduled_rides/{rideId} {
      allow read: if isOwnerOrAdmin()
        || (isAuthenticated() && resource.data.passengerId == request.auth.uid)
        || isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwnerOrAdmin()
        || (isAuthenticated() && resource.data.passengerId == request.auth.uid)
        || isAuthenticated();
      allow delete: if isOwnerOrAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // DISPATCH-DRIVER CHATS — direct messages between dispatch and drivers
    // Dispatch admins + the specific driver can read/write
    // ═══════════════════════════════════════════════════════════════════
    match /dispatch_driver_chats/{driverId} {
      allow read, write: if isOwnerOrAdmin() || isAuthenticated();

      match /messages/{messageId} {
        allow read, write: if isOwnerOrAdmin() || isAuthenticated();
      }
    }

    // ═══════════════════════════════════════════════════════════════════
    // DISPATCH NOTIFICATIONS — in-app notifications for dispatch panel
    // ═══════════════════════════════════════════════════════════════════
    match /dispatch_notifications/{notifId} {
      allow read: if isOwnerOrAdmin() || isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwnerOrAdmin() || isAuthenticated();
      allow delete: if isOwnerOrAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // DRIVER REPORTS — bug/issue reports submitted by drivers
    // ═══════════════════════════════════════════════════════════════════
    match /driver_reports/{reportId} {
      allow read: if isOwnerOrAdmin() || isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwnerOrAdmin();
      allow delete: if isOwnerOrAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // SUPPORT CHATS — rider/driver support conversations
    // ═══════════════════════════════════════════════════════════════════
    match /support_chats/{chatId} {
      allow read: if isOwnerOrAdmin() || isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwnerOrAdmin() || isAuthenticated();
      allow delete: if isOwnerOrAdmin();

      match /messages/{messageId} {
        allow read, write: if isOwnerOrAdmin() || isAuthenticated();
      }
    }

    // ═══════════════════════════════════════════════════════════════════
    // ACCOUNT APPEALS — blocked/deactivated user appeals
    // ═══════════════════════════════════════════════════════════════════
    match /account_appeals/{appealId} {
      allow read: if isOwnerOrAdmin() || isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isOwnerOrAdmin();
      allow delete: if isOwnerOrAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // ADMIN ALERTS — server/payment/security alerts from backend
    // ═══════════════════════════════════════════════════════════════════
    match /admin_alerts/{alertId} {
      allow read: if isOwnerOrAdmin();
      allow update: if isOwnerOrAdmin(); // mark as read
      allow create: if isAuthenticated(); // backend writes via service account
      allow delete: if isOwnerOrAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════
    // DENY ALL — everything else blocked
    // ═══════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
